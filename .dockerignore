# Build context exclusions for the IEP fork's HTTP wrapper image.
# Anything that doesn't need to land in the image OR shouldn't leak into a
# public registry should live here.
#
# Smaller context = faster builds and smaller images.

# Version control / IDE
.git
.github
.gitignore
.pre-commit-config.yaml

# Python build artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
build
dist
.eggs

# Virtual environments
.venv
venv
env

# Test caches
.pytest_cache
pytest-cache-files-*
.coverage
htmlcov
.tox

# Lock files (we drive deps from pyproject.toml)
uv.lock

# Editor / OS junk
.vscode
.idea
.DS_Store
Thumbs.db

# Tests don't need to ship in production image (also they pull in dev deps).
# If we ever want to run pytest inside the container we install [dev] there.
tests

# Benchmarks ditto.
benchmarks

# Deployment session artifacts — these live in the fork for record-keeping
# but should NEVER ship in a runtime image.
MemPalace_*.md
HARDENING_CHANGELOG.md
docs/deployment

# Existing assets used by README only — not needed at runtime.
assets

# Examples (sample files for users) — not needed at runtime.
examples

# Plugin manifests — only consumed by Claude Code / Codex CLIs at install time,
# not by the running HTTP server.
.claude-plugin
.codex-plugin
.agents

# Hooks (shell scripts the user installs on their laptop, not the container).
hooks
